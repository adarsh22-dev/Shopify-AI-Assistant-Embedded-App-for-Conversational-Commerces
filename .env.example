# ── Required ──────────────────────────────────────────────────────────────────
# Google Gemini API key — get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Shopify (optional — app works in demo mode without these) ─────────────────
# Your shop subdomain: e.g. "my-store" if URL is my-store.myshopify.com
SHOPIFY_SHOP_NAME=

# Shopify Admin API access token (from Partners > Apps > API credentials)
SHOPIFY_ACCESS_TOKEN=

# ── Admin Dashboard ───────────────────────────────────────────────────────────
# Password to access /admin dashboard (default: admin123 — CHANGE THIS!)
ADMIN_PASSWORD=admin123

# ── Vercel (auto-injected — do not set manually) ──────────────────────────────
# VERCEL_URL is auto-set by Vercel during deployment
